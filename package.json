{
  "name": "intellectx",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "dev:mobile": "next dev mobile-client --turbopack",
    "build": "next build",
    "build:mobile": "next build mobile-client",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test:e2e": "playwright test",
    "verify": "npm run typecheck && npm run lint && npm run test:unit && npm run build && npm run test:e2e",
    "verify:mobile-foundation": "npm run test:unit -- tests/unit/bundled-mobile-foundation.test.ts tests/unit/mobile-bundle-gates.test.ts tests/unit/android-native-security.test.ts && npm run build:mobile && npm run check:mobile-bundle && npm run check:mobile-release",
    "format": "prettier --write .",
    "convex:dev": "convex dev",
    "convex:codegen": "convex codegen",
    "test:unit": "vitest run",
    "check:prod-env": "node scripts/check-production-env.mjs",
    "check:prod-env:strict": "node scripts/check-production-env.mjs --strict",
    "check:mobile-bundle": "node scripts/check-mobile-bundle.mjs",
    "check:mobile-release": "node scripts/check-mobile-release.mjs",
    "check:mobile-release:strict": "node scripts/check-mobile-release.mjs --strict"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/cli": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@clerk/nextjs": "^7.5.12",
    "@paddle/paddle-js": "^1.4.1",
    "@radix-ui/react-accordion": "^1.2.11",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-navigation-menu": "^1.2.13",
    "@radix-ui/react-radio-group": "^1.3.7",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tabs": "^1.1.12",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "convex": "^1.42.0",
    "embla-carousel-react": "^8.6.0",
    "lucide-react": "^0.513.0",
    "motion": "^12.16.0",
    "next": "^15.4.11",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-use-measure": "^2.1.7",
    "sonner": "^2.0.5",
    "tailwind-merge": "^3.3.0",
    "vaul": "^1.1.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.3.3",
    "jsdom": "^29.1.1",
    "prettier": "^3.5.3",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.3.4",
    "typescript": "^5",
    "vitest": "^4.1.9"
  }
}
