APPLE_TEAM_ID=ABCDE12345
NEXT_PUBLIC_BUNDLE_IDENTIFIER=com.example.yourapp

NEXT_PUBLIC_PAYMENTS_ENABLED=false

NEXT_PUBLIC_APP_REDIRECT_URL=yourapp://checkout_redirect/success
NEXT_PUBLIC_PADDLE_ENV=sandbox # or `production`
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=

# Optional for IntellectX data persistence. Without this, the app uses local catalog data and browser state.
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=

# Local/dev only. Keep unset or false in production so Convex user-owned data
# requires authenticated identity instead of trusting client-supplied userKey.
ALLOW_LOCAL_USERKEY_FALLBACK=

# Optional Clerk auth. Leave blank for the local-session fallback.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Required in the Convex dashboard before adding convex/auth.config.ts.
# Example shape: https://your-clerk-instance.clerk.accounts.dev
CLERK_JWT_ISSUER_DOMAIN=

# Clerk Dashboard manual setup required:
# - Activate the Convex integration.
# - Keep the Convex JWT template name as `convex`.
# - Add one trusted staff role claim path if using staff routes/workflow:
#   staff.role, metadata.role, publicMetadata.role, or appMetadata.role.
